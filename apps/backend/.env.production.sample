# App
NODE_ENV=production
PORT=3000

# Database
# Subapage / managed PostgreSQL should be configured with a single connection string.
# Example only.
DATABASE_URL=postgres://replace-with-db-user:replace-with-db-password@replace-with-db-host:5432/replace-with-db-name?sslmode=require
DB_SSL=true
DB_SYNCHRONIZE=false

# Auth
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=https://replace-with-backend-domain/api/v1/auth/google/callback

# CORS / redirect
FRONTEND_URL=https://replace-with-frontend-domain
